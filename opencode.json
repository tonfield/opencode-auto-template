{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "openai": {
      "blacklist": ["gpt-5.5-pro"]
    },
    "kilocode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kilo OpenRouter",
      "options": {
        "baseURL": "https://api.kilo.ai/api/openrouter",
        "apiKey": "{env:KILOCODE_API_KEY}"
      },
      "models": {
        "z-ai/glm-5.1": {
          "name": "GLM 5.1",
          "limit": {
            "context": 202752,
            "output": 65535
          }
        }
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek API",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Rapid-MLX Qwen 3.6 35B",
      "options": {
        "baseURL": "http://127.0.0.1:10000/v1",
        "apiKey": "none"
      },
      "models": {
        "qwen3.6-35b": {
          "name": "Qwen 3.6 35B",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX Local Qwen 3.6",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "{env:OMLX_API_KEY}",
        "timeout": false
      },
      "models": {
        "Qwen3.6-35B-A3B-nvfp4": {
          "name": "Qwen3.6 35B A3B NVFP4 (oMLX, fastest)",
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "Qwen3.6-35B-A3B-MLX-oQ6": {
          "name": "Qwen3.6 35B A3B oQ6 (oMLX, quality middle)",
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "Qwen3.6-35B-A3B-mxfp8": {
          "name": "Qwen3.6 35B A3B MXFP8 (oMLX, high fidelity)",
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        }
      }
    }
  },

  "lsp": {
    "pyright": {
      "disabled": true
    }
  },

  "snapshot": false,

  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000,
    "tail_turns": 3,
    "preserve_recent_tokens": 30000
  },

  "watcher": {
    "ignore": [
      ".workflow-config-backups/**",
      ".opencode/node_modules/**",
      "data/apps/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".venv/**",
      "__pycache__/**",
      "tmp/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "target/**",
      ".git/**"
    ]
  },

  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "morph_edit": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "external_directory": "allow",
    "task": { "*": "deny" },
    "mcp": { "*": "allow" }
  },

  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "timeout": 30000,
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "timeout": 30000,
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa&exaApiKey={env:EXA_API_KEY}",
      "timeout": 30000,
      "enabled": true
    },
    "ast-grep": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/ast-grep/ast-grep-mcp", "ast-grep-server"],
      "timeout": 30000,
      "enabled": true
    }
  },

  "experimental": {
    "mcp_timeout": 30000
  },

  "tool_output": {
    "max_lines": 300,
    "max_bytes": 12000
  },

  "default_agent": "auto",

  "instructions": [
    "./instructions/feature-workflow.md",
    "./instructions/shell-noninteractive.md",
    "node_modules/@morphllm/opencode-morph-plugin/instructions/morph-tools.md"
  ],

  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "@morphllm/opencode-morph-plugin",
    "opencode-background-agents@latest",
    "opencode-snip@latest"
  ],

  "agent": {
    "general": {
      "disable": true
    },
    "auto": {
      "mode": "primary"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  }
}
